# ClawComms environment — copy to .env and fill in
# NEVER commit .env to git

# WRK passphrase — Bootstrap CLI only (docker compose --profile tools run bootstrap-cli)
RELAY_WRK_PASSPHRASE=changeme

# IEK passphrase — Enrollment Service uses this to decrypt IEK private key at startup
# Can be the same as WRK passphrase or different for extra separation
RELAY_IEK_PASSPHRASE=changeme

# Admin token — required to call /revoke endpoint
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=changeme

# Enrollment Service tuning (optional)
BC_TTL_SECONDS=900
LOG_LEVEL=INFO
